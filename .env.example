# GitHub Personal Access Token (classic) with repo scope
# Generate at: github.com/settings/tokens
GITHUB_TOKEN=your_token_here

# Target repository to commit to (owner/repo format)
# This is the separate "farm" repo, not this one
TARGET_REPO=thedevonstone/dev-til

# Your GitHub username
GITHUB_USERNAME=thedevonstone

# Commit author identity
GIT_AUTHOR_NAME=Devon Stone
GIT_AUTHOR_EMAIL=thedevonstone@gmail.com

# Intensity profile: light | medium | heavy
INTENSITY=medium

# Dry run — logs what would happen without making real commits
# Set to true for testing
DRY_RUN=false
